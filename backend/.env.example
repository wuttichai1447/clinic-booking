APP_NAME="Clinic Booking API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=
CRON_KEY=

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=booking
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=database
# sync = ประมวลผลทันที | database = ใช้ php artisan queue:work

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
# จำกัดเวลาเชื่อมต่อ SMTP (วินาที) กันไม่ให้การจองค้างหากโฮสต์บล็อก outbound SMTP
MAIL_TIMEOUT=8
MAIL_FROM_ADDRESS=booking@example.com
MAIL_FROM_NAME="${APP_NAME}"

ADMIN_NOTIFY_EMAIL=admin@example.com

# ntfy — แจ้งแอดมินบนมือถือ (แอป ntfy subscribe ตาม topic)
NTFY_ENABLED=false
NTFY_TOPIC=clinic-booking-your-unique-name
NTFY_SERVER=https://ntfy.sh

BOOKING_SLOT_LOCK_MINUTES=15
BOOKING_REMINDERS_ENABLED=true
BOOKING_REMINDER_DAY_HOURS=24
BOOKING_REMINDER_SHORT_HOURS=2
BOOKING_REMINDER_WINDOW_MINUTES=30
REFUND_FULL_HOURS=24
REFUND_PARTIAL_PERCENT=50
REFUND_PARTIAL_HOURS=12
REFUND_NONE_HOURS=2
# Telegram Bot — แจ้งแอดมิน (ทดแทน LINE Notify ที่ยุตแล้ว)
# สร้างบอทที่ @BotFather แล้วเอา chat_id จาก @userinfobot หรือกลุ่ม
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMS ลูกค้า — HTTP API (POST JSON: phone, message) จากผู้ให้บริการ SMS ไทย
SMS_ENABLED=false
SMS_API_URL=
SMS_API_KEY=

SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

# Stripe (https://dashboard.stripe.com/test/apikeys)
STRIPE_KEY=pk_test_your_key
STRIPE_SECRET=sk_test_your_secret
# Webhook: POST http://127.0.0.1:8000/api/v1/stripe/webhook
# stripe listen --forward-to http://127.0.0.1:8000/api/v1/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# false = ชำระจริง (Stripe + โอน/พร้อมเพย์รอแอดมิน) | true = จำลองชำระทันที (ทดสอบ)
PAYMENT_DEV_MODE=false

# โอนเงิน / พร้อมเพย์ (แสดงให้ลูกค้าเมื่อไม่ใช่โหมด dev)
PAYMENT_BANK_NAME="ธนาคารกสิกรไทย"
PAYMENT_BANK_ACCOUNT_NAME="Clinic Booking Co., Ltd."
PAYMENT_BANK_ACCOUNT=123-4-56789-0
PAYMENT_PROMPTPAY_ID=0812345678

# Partners API (optional external submit)
PARTNERS_API_ENABLED=false
PARTNERS_API_URL=
PARTNERS_API_KEY=

ADMIN_EMAIL=admin@booking.local
ADMIN_PASSWORD=password

# OAuth (Google / Facebook) — redirect URIs must match provider console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/google/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/facebook/callback
